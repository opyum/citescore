# Copy to .env and fill in. NEVER commit the real .env.
# Strong random values — generate with:  openssl rand -hex 24

# Postgres password used by docker-compose (app + db share it)
DB_PASSWORD=change-me-long-random

# Token to read your leads at /api/leads?token=...   (keep secret)
ADMIN_TOKEN=change-me-long-random

# Only if you point at an EXTERNAL Postgres instead of the compose db:
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# PGSSL=true
